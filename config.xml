<?xml version='1.0' encoding='utf-8'?>
<widget id="com.launcher.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>My Launcher</name>
    <description>Android Home Launcher with Custom Icons</description>
    <author email="app@launcher.com">Developer</author>
    
    <content src="index.html" />
    
    <allow-navigation href="*" />
    <access origin="*" />
    
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    
    <platform name="android">
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="30" />
        <preference name="AndroidXEnabled" value="true" />
        
        <config-file target="AndroidManifest.xml" parent="/manifest/application/activity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </config-file>
        
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
            <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.SET_WALLPAPER" />
            <uses-permission android:name="android.permission.INTERNET" />
        </config-file>
    </platform>
</widget>
